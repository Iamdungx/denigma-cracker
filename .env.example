# DEnigmaCracker v2.0 - Environment Configuration
# Copy this file to env.local and fill in your values

# ===========================================
# REQUIRED: Ethereum (Etherscan API)
# Get your key at: https://etherscan.io/apis
# ===========================================
ETHERSCAN_API_KEY=

# ===========================================
# OPTIONAL: BNB Smart Chain (BscScan API)
# Get your key at: https://bscscan.com/apis
# ===========================================
BSCSCAN_API_KEY=

# ===========================================
# OPTIONAL: Override default settings
# ===========================================
# LOG_LEVEL=INFO
# SCANNER_WORKERS=4
